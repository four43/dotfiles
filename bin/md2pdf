def _alert_icon(kind: str) -> str:
    name, path_d = ALERT_ICON_PATHS[kind]
    color = ALERT_COLORS[kind]
    return (
        f'<svg class="octicon octicon-{name}" viewBox="0 0 16 16" '
        f'width="16" height="16" fill="{color}" aria-hidden="true">'
        f'<path d="{path_d}"/></svg>'
    )


class GfmAlertPreprocessor(Preprocessor):
    """Convert GitHub-flavored alert blockquotes to styled divs."""

    HEADER_RE = re.compile(
        r"^>\s*\[!(" + "|".join(t.upper() for t in ALERT_TYPES) + r")\]\s*$"
    )
    QUOTE_RE = re.compile(r"^>\s?(.*)$")

    def run(self, lines):
        result = []
        i = 0
        while i < len(lines):
            m = self.HEADER_RE.match(lines[i])
            if not m:
                result.append(lines[i])
                i += 1
                continue

            kind = m.group(1).lower()
            i += 1
            body = []
            while i < len(lines):
                bm = self.QUOTE_RE.match(lines[i])
                if not bm:
                    break
                body.append(bm.group(1))
                i += 1

            title = f"{_alert_icon(kind)} {kind.capitalize()}"
            result.append(f'<div class="markdown-alert markdown-alert-{kind}" markdown="1">')
            result.append(f'<p class="markdown-alert-title">{title}</p>')
            result.append("")
            result.extend(body)
            result.append("")
            result.append("</div>")

        return result


class GfmAlertExtension(Extension):
    def extendMarkdown(self, md):
        md.preprocessors.register(GfmAlertPreprocessor(md), "gfm_alert", 100)


def md_to_html(md_text: str) -> str:
    extensions = [
        "markdown.extensions.tables",
        "markdown.extensions.fenced_code",
        "markdown.extensions.codehilite",
        "markdown.extensions.toc",
        "markdown.extensions.sane_lists",
        "markdown.extensions.smarty",
        "markdown.extensions.nl2br",
        "markdown.extensions.md_in_html",
        GfmAlertExtension(),
    ]
    extension_configs = {
        "markdown.extensions.codehilite": {"css_class": "highlight", "guess_lang": False},
    }
    return markdown.markdown(md_text, extensions=extensions, extension_configs=extension_configs)


def build_document(body_html: str, css_path: Path) -> str:
    css = css_path.read_text()
    return f"""<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>{css}</style>
</head>
<body>
{body_html}
</body>
</html>"""


def main():
    parser = argparse.ArgumentParser(description="Convert Markdown to PDF")
    parser.add_argument("input", help="Input markdown file")
    parser.add_argument("-o", "--output", help="Output PDF file (default: <input>.pdf)")
    parser.add_argument("--css", type=Path, default=DEFAULT_CSS, help="Custom CSS file")
    args = parser.parse_args()

    input_path = Path(args.input)
    if not input_path.exists():
        sys.exit(f"File not found: {input_path}")

    output_path = Path(args.output) if args.output else input_path.with_suffix(".pdf")

    md_text = input_path.read_text()
    body_html = md_to_html(md_text)
    document = build_document(body_html, args.css)

    HTML(string=document, base_url=str(input_path.parent)).write_pdf(str(output_path))
    print(f"{output_path}")


if __name__ == "__main__":
    main()
