#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "markdown",
#     "weasyprint",
# ]
# ///
"""Convert a Markdown file to PDF with GitHub-flavored styling."""

import argparse
import re
import sys
from pathlib import Path

import markdown
from markdown.extensions import Extension
from markdown.preprocessors import Preprocessor
from weasyprint import HTML

DEFAULT_CSS = Path(__file__).resolve().parent / "md2pdf-markdown.css"

ALERT_TYPES = ("note", "tip", "important", "warning", "caution")
ALERT_COLORS = {
    "note": "#0969da",
    "tip": "#1a7f37",
    "important": "#8250df",
    "warning": "#9a6700",
    "caution": "#cf222e",
}

# Octicon SVG path data pulled from GitHub's own rendering
# (see https://github.com/orgs/community/discussions/16925).
