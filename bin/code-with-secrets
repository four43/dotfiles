#!/usr/bin/env bash
# Launch VS Code with secrets pulled from `pass` (GPG-encrypted password store).
#
# KDE GUI launchers do NOT source ~/.zshrc / ~/.zprofile, so secrets exported
# there are invisible to apps started from the menu/KRunner. This wrapper is
# what ~/.local/share/applications/code.desktop calls instead of /usr/bin/code:
# it decrypts secrets from `pass` at launch time and exports them into VS Code's
# process tree ONLY -- never session-wide, never plaintext on disk.
#
# First launch after login triggers a graphical GPG passphrase prompt
# (pinentry-qt); subsequent launches reuse the cached gpg-agent session.
#
# To add a secret:  pass insert env/my-new-key   then add a line below.
set -uo pipefail

# ENV_VAR  ->  pass entry path (one secret value per entry)
declare -A SECRETS=(
	[XWE_GITHUB_TOKEN]="github.com/VaisalaCorp/PAT_Non_Destructive_CLI"
	[XWE_ATLASSIAN_EMAIL]="vaisala.atlassian.net/email"
	[XWE_ATLASSIAN_API_TOKEN]="vaisala.atlassian.net/api_token"
	[XWE_API_CLIENT_ID]="xweather.com/api/client_id"
	[XWE_API_CLIENT_SECRET]="xweather.com/api/client_secret"
)

for var in "${!SECRETS[@]}"; do
	entry="${SECRETS[$var]}"
	if value="$(pass show "$entry" 2>/dev/null | head -n1)" && [[ -n "$value" ]]; then
		export "$var=$value"
	else
		printf 'code-with-secrets: warning: no pass entry %q for %s\n' "$entry" "$var" >&2
	fi
done

exec /usr/bin/code "$@"
